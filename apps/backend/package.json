{
  "name": "@crystal-diy/backend",
  "version": "0.1.0",
  "private": true,
  "description": "一念一串 NestJS API",
  "scripts": {
    "build": "rm -f tsconfig.build.tsbuildinfo && tsc -p tsconfig.build.json",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "ts-node -r tsconfig-paths/register src/main.ts",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage"
  },
  "dependencies": {
    "@nestjs/bullmq": "latest",
    "@nestjs/common": "latest",
    "@nestjs/config": "latest",
    "@nestjs/core": "latest",
    "@nestjs/jwt": "latest",
    "@nestjs/mongoose": "latest",
    "@nestjs/passport": "latest",
    "@nestjs/platform-express": "latest",
    "@nestjs/schedule": "latest",
    "@nestjs/swagger": "latest",
    "@nestjs/throttler": "latest",
    "bcryptjs": "latest",
    "bullmq": "latest",
    "class-transformer": "latest",
    "class-validator": "latest",
    "compression": "latest",
    "dayjs": "latest",
    "helmet": "latest",
    "ioredis": "latest",
    "mongoose": "latest",
    "multer": "latest",
    "nestjs-pino": "latest",
    "passport": "latest",
    "passport-jwt": "latest",
    "pino": "latest",
    "reflect-metadata": "latest",
    "rxjs": "latest",
    "joi": "latest"
  },
  "devDependencies": {
    "@eslint/eslintrc": "latest",
    "@eslint/js": "latest",
    "@nestjs/cli": "latest",
    "@nestjs/schematics": "latest",
    "@nestjs/testing": "latest",
    "@swc/cli": "latest",
    "@swc/core": "latest",
    "@types/bcryptjs": "latest",
    "@types/compression": "latest",
    "@types/express": "latest",
    "@types/jest": "latest",
    "@types/multer": "latest",
    "@types/node": "latest",
    "@types/passport-jwt": "latest",
    "eslint": "latest",
    "eslint-config-prettier": "latest",
    "eslint-plugin-prettier": "latest",
    "globals": "latest",
    "jest": "latest",
    "prettier": "latest",
    "source-map-support": "latest",
    "supertest": "latest",
    "ts-jest": "latest",
    "ts-loader": "latest",
    "ts-node": "latest",
    "tsconfig-paths": "latest",
    "typescript": "latest",
    "typescript-eslint": "latest",
    "pino-pretty": "latest"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
